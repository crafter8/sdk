{
  "name": "Crafter8 SDK",
  "dockerComposeFile": [
    "../compose.sdk-dev.yml"
  ],
  "service": "sdk-dev",
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",
  "remoteUser": "node",
  "remoteEnv": {
    "CRAFTER8_SDK_GITHUB_REPO": "crafter8/sdk"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-vscode.vscode-typescript-next"
      ]
    }
  },
  "postCreateCommand": "bash -lc 'npm test'"
}
